BootStrap: docker
From: ubuntu:20.04

%labels
    Author Adel Baselizadeh
    Version 1.0
    Description Ubuntu 20.04 sandbox for Singularity

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH

%post
    # Update and install some basic packages
    apt-get update && apt-get upgrade -y
    apt-get install -y build-essential sudo vim wget curl git ca-certificates

    # Clean up
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    echo "Welcome to the Ubuntu 20.04 Singularity sandbox!"
    exec /bin/bash

